/* File: style/style.css */

/* 1. Base & Reset */
@import url('./base.css');

/* 2. Main Layout Structure */
@import url('./layout.css');

/* 3. Components */
@import url('./sidebar.css');
@import url('./modals.css');
@import url('./xml-editor.css');
@import url('./gui-elements.css');
@import url('./modulation-links.css');

/* Fix image-based SVG buttons showing an unwanted background frame */
[data-xml-tag-name="Button"],
[data-xml-tag-name="Button"] img,
[data-xml-tag-name="Button"] svg {
    background: transparent !important;
    background-color: transparent !important;
    border: none !important;
    outline: none !important;
    box-shadow: none !important;
    padding: 0 !important;
}

/* 4. Animations & Effects */
@import url('./animations.css');